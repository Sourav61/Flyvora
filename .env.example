# Firebase Configuration (Replace with your actual values)
REACT_APP_API_KEY="your_firebase_api_key_here"
REACT_APP_AUTH_DOMAIN="your_project.firebaseapp.com"
REACT_APP_PROJECT_ID="your_project_id_here"
REACT_APP_STORAGE_BUCKET="your_project.appspot.com"
REACT_APP_MESSAGING_SENDER_ID="123456789"
REACT_APP_APP_ID="1:123456789:web:abcdef123456"
REACT_APP_MEASUREMENT_ID="G-ABCDEF123"

# Auth0 Configuration (Replace with your actual values)
REACT_APP_AUTH0_DOMAIN="your_auth0_domain.auth0.com"
REACT_APP_AUTH0_CLIENT_ID="your_auth0_client_id_here"
REACT_APP_API_BASE_URL="http://localhost:5000"

# Admin Dashboard Credentials
ADMIN_DASHBOARD_USERNAME="admin"
ADMIN_DASHBOARD_PASSWORD="FlyvoraDemo123!"

# Backend Configuration
PORT=5000
FRONTEND_ORIGIN="http://localhost:5001,http://localhost:3000,http://localhost:3001"
CHECKOUT_RETURN_ORIGIN="http://localhost:5001"
DB_HOST="localhost"
DB_PORT=5432
DB_USER="postgres"
DB_PASSWORD="your_postgres_password"
DB_NAME="travel_pro"
# DATABASE_URL="postgresql://postgres:password@localhost:5432/travel_pro"
JWT_SECRET="replace_with_a_strong_secret"

# Dodo Payments Configuration
# DODO_PAYMENTS_PRODUCT_ID should be a pay-what-you-want product so flight totals can be passed dynamically.
DODO_PAYMENTS_ENV="test_mode"
DODO_PAYMENTS_API_KEY="dp_test_your_api_key"
DODO_PAYMENTS_PRODUCT_ID="prod_your_dynamic_checkout_product"

